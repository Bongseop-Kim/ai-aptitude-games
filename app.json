{
  "expo": {
    "name": "역검",
    "slug": "ai-aptitude-games",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "aiaptitudegames",
    "experiments": {
      "typedRoutes": true
    },
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bongsub.aiaptitudegames",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "모의 면접 영상 답변을 위해 카메라 접근이 필요해요."
      },
      "appleTeamId": "Z995BAAVG5"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.bongsub.aiaptitudegames",
      "predictiveBackGestureEnabled": false
    },
    "extra": {
      "eas": {
        "projectId": "a00249ab-13c4-4a37-ad29-3bf408d2e3cc"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-web-browser",
      "expo-router",
      "expo-splash-screen",
      [
        "expo-camera",
        {
          "cameraPermission": "모의 면접 영상 답변을 위해 카메라 접근이 필요해요.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "면접 답변 녹음을 위해 마이크 접근이 필요해요."
        }
      ],
      "expo-asset"
    ]
  }
}
